# --- LLM judges -------------------------------------------------------------
# Required only for the three LLM-judge scorers. The six deterministic scorers
# run without it — `python -m src.run --no-llm` needs no key at all.
OPENAI_API_KEY=sk-...

# Judge model. GPT-4o is the default because the judges reason over a whole step
# log; a smaller model scores trajectories inconsistently, which shows up as
# noise and makes the regression detector useless.
JUDGE_MODEL=gpt-4o
# Used for cheap sub-scores where the reasoning burden is lighter.
CHEAP_MODEL=gpt-4o-mini
# Retries per judge call (exponential backoff between attempts).
JUDGE_MAX_RETRIES=3

# --- storage ----------------------------------------------------------------
DB_PATH=data/harness.db
RUNS_DIR=data/runs
REPORTS_DIR=data/reports

# --- regression thresholds --------------------------------------------------
# A dimension must drop by more than this AND clear the statistical noise band
# before it is called a regression. Lower = more sensitive and more false alarms.
REGRESSION_THRESHOLD=0.05
# Same, for the weighted overall score.
OVERALL_THRESHOLD=0.03
# How many recent runs the slow-drift check looks back over.
DRIFT_WINDOW=5
# Cumulative drop across that window that counts as drift, even when no single
# comparison ever tripped REGRESSION_THRESHOLD.
DRIFT_THRESHOLD=0.08

# --- runner -----------------------------------------------------------------
# Repeats per task. 1 gives you no variance estimate, so the regression detector
# has no noise band and falls back to the raw threshold. 3+ is the honest floor.
REPEATS=3
WORKERS=4
# Identical tool+input calls at or above this count are flagged as a loop.
LOOP_REPEAT_LIMIT=3

# --- agent under test -------------------------------------------------------
# Read by src/agents_under_test/ads.py, not by the harness core.
AGENT_UNDER_TEST_PATH=../autonomous-data-scientist
